# ─────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────
SERVER_PORT=8080
# The port the HTTP server listens on

SERVER_READ_TIMEOUT_SECONDS=30
# Max time in seconds to read an incoming request

SERVER_WRITE_TIMEOUT_SECONDS=30
# Max time in seconds to write a response

SERVER_IDLE_TIMEOUT_SECONDS=120
# Max time a keep-alive connection stays open with no requests

SERVER_SHUTDOWN_TIMEOUT_SECONDS=30
# Grace period in seconds when shutting down — workers finish in-flight requests

# ─────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────
DB_PATH=./data/pool.db
# Path to the SQLite database file inside the container

DB_MAX_OPEN_CONNS=1
# SQLite must use 1 open connection — it does not support concurrent writes

DB_BUSY_TIMEOUT_MS=5000
# How long SQLite waits (ms) if the DB is locked before returning an error

# ─────────────────────────────────────────────
# SECURITY
# ─────────────────────────────────────────────
ENCRYPTION_KEY=
# 32-byte hex string used for AES-256-GCM encryption of API key values in DB
# Generate with: openssl rand -hex 32
# NEVER commit a real value here — this is the example file

ADMIN_TOKEN=
# Bearer token required to call /admin/* endpoints
# Generate with: openssl rand -hex 32
# All admin requests must include: Authorization: Bearer <token>

# ─────────────────────────────────────────────
# WORKER POOL
# ─────────────────────────────────────────────
WORKER_COUNT=10
# Number of concurrent workers processing requests from the queue
# Rule of thumb: (total_keys * avg_rate_limit_per_second) / avg_api_latency_seconds

WORKER_WARMUP_SECONDS=30
# On startup, workers run at 25% capacity for this many seconds
# Prevents thundering herd when server restarts with a backlogged queue

# ─────────────────────────────────────────────
# QUEUE
# ─────────────────────────────────────────────
QUEUE_MAX_SIZE=1000
# Maximum number of requests that can sit in the queue at once
# When full: Low priority requests are rejected with 503

QUEUE_HIGH_PRIORITY_PREEMPTS_LOW=true
# When queue is full and a High priority request arrives,
# drop the oldest Low priority item to make room

# ─────────────────────────────────────────────
# KEY POOL
# ─────────────────────────────────────────────
KEY_POOL_STRATEGY=round_robin
# Which key selection algorithm to use
# Options: round_robin | weighted_round_robin

KEY_POOL_RELOAD_INTERVAL_SECONDS=60
# How often the pool reloads keys from DB to pick up additions or weight changes

KEY_POOL_HEALTH_CHECK_INTERVAL_SECONDS=10
# How often the pool checks healthy key ratio for load shedding decisions

# ─────────────────────────────────────────────
# CIRCUIT BREAKER
# ─────────────────────────────────────────────
CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
# Number of consecutive failures before a key's circuit opens (key removed from rotation)

CIRCUIT_BREAKER_OPEN_DURATION_SECONDS=60
# How long a key stays in Open state before moving to Half-Open for probe

CIRCUIT_BREAKER_PROBE_TIMEOUT_SECONDS=10
# Timeout for the single probe request sent in Half-Open state

# ─────────────────────────────────────────────
# RETRY
# ─────────────────────────────────────────────
RETRY_MAX_ATTEMPTS=4
# Total number of attempts per request (1 original + 3 retries)

RETRY_BASE_DELAY_MS=1000
# Base delay in milliseconds for exponential backoff
# Formula: delay = BASE * 2^attempt + jitter
# Attempt 0: ~1s, Attempt 1: ~2s, Attempt 2: ~4s, Attempt 3: ~8s

RETRY_MAX_DELAY_MS=30000
# Cap on retry delay — backoff will never exceed this value regardless of formula

RETRY_JITTER_MAX_MS=500
# Maximum random jitter added to each retry delay to prevent thundering herd

# ─────────────────────────────────────────────
# HTTP CLIENT
# ─────────────────────────────────────────────
HTTP_CLIENT_TIMEOUT_SECONDS=30
# Timeout for each outbound HTTP call to the external API

HTTP_CLIENT_MAX_IDLE_CONNS=100
# Max idle connections in the HTTP client connection pool

HTTP_CLIENT_IDLE_CONN_TIMEOUT_SECONDS=90
# How long an idle connection stays open before being closed

# ─────────────────────────────────────────────
# LOAD SHEDDING
# ─────────────────────────────────────────────
LOAD_SHED_LEVEL_1_THRESHOLD=0.50
# When healthy keys drop below 50% of total: reject Low priority requests

LOAD_SHED_LEVEL_2_THRESHOLD=0.25
# When healthy keys drop below 25% of total: reject Low and Normal priority requests
# Only High priority requests are accepted at this level

# ─────────────────────────────────────────────
# CONFIG HOT RELOAD
# ─────────────────────────────────────────────
CONFIG_RELOAD_INTERVAL_SECONDS=30
# How often the server re-reads system_config from DB to apply runtime changes
# Affects: worker_count, strategy, queue size, circuit breaker thresholds

# ─────────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────────
LOG_LEVEL=info
# Minimum log level to output
# Options: debug | info | warn | error

LOG_FORMAT=json
# Log output format
# Options: json (production) | pretty (local development)

LOG_REQUESTS=true
# Whether to log every incoming HTTP request (method, path, status, duration)

# ─────────────────────────────────────────────
# METRICS
# ─────────────────────────────────────────────
METRICS_ENABLED=true
# Whether to expose the /metrics endpoint

METRICS_PATH=/metrics
# Path where Prometheus metrics are served
